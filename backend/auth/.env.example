# Copy this file to .env and fill in the values.

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-long-random-secret-here

# Google OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# PostgreSQL connection string (Neon.tech free tier recommended)
# Leave unset to use SQLite for local development (zero setup required)
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
